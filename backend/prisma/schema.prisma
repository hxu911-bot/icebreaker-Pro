generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  isAdmin      Boolean   @default(false)
  cooldownDays Int       @default(90)
  dashscopeKey String?
  smtpHost     String?
  smtpPort     Int?
  smtpUser     String?
  smtpPass     String?
  smtpFrom     String?
  createdAt    DateTime  @default(now())
  campaigns    Campaign[]
  profiles     SenderProfile[]
}

model SenderProfile {
  id          String     @id @default(uuid())
  userId      String
  name        String
  title       String
  company     String
  role        String
  signature   String
  personalNote String?
  isDefault   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id])
  campaigns   Campaign[]
}

model Campaign {
  id          String      @id @default(uuid())
  userId      String
  profileId   String?
  name        String
  jobTitle    String?
  style       String      @default("PROFESSIONAL")
  language    String      @default("English")
  emailCount  Int         @default(1)
  status      String      @default("DRAFT")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id])
  profile     SenderProfile? @relation(fields: [profileId], references: [id])
  candidates  Candidate[]
}

model Candidate {
  id            String    @id @default(uuid())
  campaignId    String
  name          String?
  email         String?
  rawText       String
  source        String
  status        String    @default("PENDING")
  recruiterNote String?
  sourceUrl     String?
  replied          Boolean   @default(false)
  repliedAt        DateTime?
  sentCount        Int       @default(0)
  regenRequestedAt DateTime?
  regenReason      String?
  createdAt        DateTime  @default(now())
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  emails        GeneratedEmail[]
  sendLogs      SendLog[]
}

model GeneratedEmail {
  id          String    @id @default(uuid())
  candidateId String
  subject     String
  body        String
  style       String    @default("AUTO")
  approved    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model SendLog {
  id          String    @id @default(uuid())
  candidateId String
  toEmail     String
  subject     String
  status      String
  error       String?
  sentAt      DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([toEmail])
}
